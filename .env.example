# 【必填】會話密鑰，>change-to-a-long-random-string< 顧名思義
# 隨機生成一個長字符串填回去
SESSION_SECRET=change-me-to-a-long-random-string

# ------------------ 資料庫配置 ------------------ #
## 資料庫默認SQLite，目錄在 ./data/boards.sqlite(下面默認)
## 你會發現沒有data這個資料夾和SQLite文件，沒關係，啟動後會自動生成

# 【必填】資料庫方言：sqlite | postgres | mariadb
DATABASE_DIALECT=sqlite

# 【必填】資料庫連線（SQLite 為檔案路徑，相對項目根目錄）
DATABASE_URL=./data/boards.sqlite

# PostgreSQL 示例
# DATABASE_DIALECT=postgres
# DATABASE_URL=postgresql://user:password@localhost:5432/ripples_webboard

# MariaDB 示例
# DATABASE_DIALECT=mariadb
# DATABASE_URL=mysql://user:password@localhost:3306/ripples_webboard

# ------------------ 站點配置 ------------------ #
# 【必填】站點 URL（電郵連結等）
SITE_URL=http://localhost:3100

# 【必填】審核電郵通知：true 啟用 | false 關閉
NOTIFY_EMAIL_ENABLED=false
# 以下 SMTP 項均必填；關閉電郵時 SMTP_HOST 可留空
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
# 如果是Gmail那樣的應用程式密碼(abcd efgh ijkl mnop qrst uvwx yz)這樣的
# 請去掉空格，直接填入(abcdefghijklmnopqrstuvwxyz)
SMTP_PASS=
SMTP_FROM=Ripples WebBoard <noreply@example.com>

# 【必填】需要邀請碼註冊：true 需要 | false 不需要
REGISTRATION_INVITE_REQUIRED=true
# 邀請註冊時展示的聯繫電郵；開放註冊時可留空
REGISTRATION_CONTACT_EMAIL=admin@example.com

# 禁止註冊的用戶名（逗號分隔）。無 * 為精確匹配；含 * 為通配（* 表示任意字元）
REGISTRATION_BLOCKED_USERNAMES=admin,*admin*,system,root

# ------------------ 登入防護(下面非特別需要，請勿改) ------------------ #
## 登入防暴力破解（按 IP / 用戶名滑動窗口 + 臨時封禁）
LOGIN_IP_MAX_ATTEMPTS=30
LOGIN_IP_WINDOW_MS=900000
LOGIN_IP_LOCKOUT_MS=900000
LOGIN_USER_MAX_ATTEMPTS=8
LOGIN_USER_WINDOW_MS=900000
LOGIN_USER_LOCKOUT_MS=1800000

# 註冊防刷（按 IP 限制）
REGISTER_IP_MAX_ATTEMPTS=5
REGISTER_IP_WINDOW_MS=3600000
REGISTER_IP_LOCKOUT_MS=3600000
